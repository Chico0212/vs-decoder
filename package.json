{
  "name": "vscode-decoder",
  "displayName": "Decocder",
  "description": "A base64 and gzip-base64 decoder",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-decoder.base64",
        "title": "Decode base64"
      },
      {
        "command": "vscode-decoder.gzipb64",
        "title": "Decode gzipBase64"
      }
    ],
    "submenus": [
      {
        "label": "VS decoder",
        "id": "decoder"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "decoder",
          "group": "9_cutcopypaste"
        }
      ],
      "decoder": [
        {
          "command": "vscode-decoder.base64"
        },
        {
          "command": "vscode-decoder.gzipb64"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run package",
    "compile": "bun x webpack",
    "watch": "bun x webpack --watch",
    "package": "bun x webpack --mode production --devtool hidden-source-map",
    "compile-tests": "bun x tsc -p . --outDir out",
    "watch-tests": "bun x tsc -p . -w --outDir out",
    "pretest": "bun run compile-tests && bun run compile && bun run lint",
    "lint": "bun x eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "dependencies": {
    "@types/bun": "^1.3.10"
  }
}
